									"pm.test('Store selected event id when list is not empty', function () {",
									"  const events = pm.response.json();",
									"  if (!Array.isArray(events) || events.length === 0) {",
									"    return;",
									"  }",
									"",
									"  const preferredSlug = pm.collectionVariables.get('seedEventSlug');",
									"  const selectedEvent = events.find((event) => event.slug === preferredSlug) ?? events[0];",
									"  pm.collectionVariables.set('eventId', selectedEvent.id);",
									"});"
